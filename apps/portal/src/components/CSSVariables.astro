---
import * as styles from "@harnessio/core-design-system/styles-esm";

type Var = {
  name: string;
  value: string;
  description: string;
  category: string;
  subcategory: string;
  twClasses: string[];
};

function extractVariables(obj: any): Var[] {
  const vars: Var[] = [];
  for (const key in obj) {
    const item = obj[key];
    if (item && typeof item === "object") {
      if (item.name && item.$value !== undefined) {
        vars.push({
          name: `--${item.name}`,
          value: String(item.$value),
          description: item.$description || "",
          category: "",
          subcategory: "",
          twClasses: [],
        });
      } else {
        vars.push(...extractVariables(item));
      }
    }
  }
  return vars;
}

// --- CSS variable → Tailwind class mapping ---
const SET_COLOR_MAP: Record<string, string> = { "forest-green": "forest" };

function getTwClasses(n: string): string[] {
  let m: RegExpMatchArray | null;

  // bg: --cn-bg-{N} → bg-cn-{N}
  if ((m = n.match(/^--cn-bg-(\d)$/))) return [`bg-cn-${m[1]}`];

  // text: --cn-text-{N} → text-cn-{N}
  if ((m = n.match(/^--cn-text-(\d)$/))) return [`text-cn-${m[1]}`];
  if (n === "--cn-text-merged") return ["text-cn-merged"];
  if (n === "--cn-text-brand") return ["text-cn-brand"];
  if (n === "--cn-text-success") return ["text-cn-success"];
  if (n === "--cn-text-danger") return ["text-cn-danger"];
  if (n === "--cn-text-warning") return ["text-cn-warning"];

  // border: --cn-border-{N} → border-cn-{N}
  if ((m = n.match(/^--cn-border-(\d)$/))) return [`border-cn-${m[1]}`];
  if (n === "--cn-border-brand") return ["border-cn-brand"];
  if (n === "--cn-border-success") return ["border-cn-success"];
  if (n === "--cn-border-danger") return ["border-cn-danger"];
  if (n === "--cn-border-warning") return ["border-cn-warning"];
  if (n === "--cn-state-disabled-border") return ["border-cn-disabled"];

  // state: --cn-state-hover/selected → bg-cn-hover/selected
  if (n === "--cn-state-hover") return ["bg-cn-hover"];
  if (n === "--cn-state-selected") return ["bg-cn-selected"];

  // set tokens: --cn-set-{color}-{variant}-{prop}[-suffix]
  if (
    (m = n.match(
      /^--cn-set-(.+?)-(primary|secondary|outline)-(bg|text|border)(-hover|-selected)?$/,
    ))
  ) {
    const [, raw, variant, prop, suffix] = m;
    const c = SET_COLOR_MAP[raw] || raw;
    const pfx = prop === "bg" ? "bg" : prop === "text" ? "text" : "border";
    return [`${pfx}-cn-${c}-${variant}${suffix || ""}`];
  }

  // border radius: --cn-rounded-{val} → rounded-cn-{val}
  if ((m = n.match(/^--cn-rounded-(.+)$/))) return [`rounded-cn-${m[1]}`];

  // shadows: --cn-shadow-{N}
  if (n === "--cn-shadow-0") return ["shadow-cn-none"];
  if ((m = n.match(/^--cn-shadow-(\d)$/))) return [`shadow-cn-${m[1]}`];

  // rings: --cn-ring-{type} → shadow-cn-ring-{type}
  if ((m = n.match(/^--cn-ring-(.+)$/))) return [`shadow-cn-ring-${m[1]}`];

  // spacing: --cn-layout-{size} → gap/p/m-cn-{size}
  if ((m = n.match(/^--cn-layout-(.+)$/)))
    return [`gap-cn-${m[1]}`, `p-cn-${m[1]}`, `m-cn-${m[1]}`];
  if (n === "--cn-spacing-0") return ["gap-0", "p-0", "m-0"];
  if (n === "--cn-spacing-px") return ["gap-px", "p-px", "m-px"];

  // font size: --cn-font-size-{N} → text-cn-size-{N}
  if ((m = n.match(/^--cn-font-size-(\d+)$/))) return [`text-cn-size-${m[1]}`];

  // letter spacing: --cn-tracking-{name} → tracking-cn-{name}
  if ((m = n.match(/^--cn-tracking-(.+)$/))) return [`tracking-cn-${m[1]}`];

  // size tokens: --cn-size-{N} → w-cn-{N}, h-cn-{N}
  if ((m = n.match(/^--cn-size-(\d+)$/)))
    return [`w-cn-${m[1]}`, `h-cn-${m[1]}`];

  // font weight: --cn-font-weight-{name} → font-{name} (standard TW)
  if ((m = n.match(/^--cn-font-weight-(.+)$/))) return [`font-[var(${n})]`];

  // opacity
  if (n === "--cn-disabled-opacity") return ["opacity-cn-disabled"];

  // logo
  if (n === "--cn-logo-icon") return ["text-cn-logo-icon"];
  if (n === "--cn-logo-text") return ["text-cn-logo-text"];

  // typography composites (plugin utilities)
  const typoPatterns: [RegExp, string][] = [
    [/^--cn-heading-(.+)$/, "font-heading-"],
    [/^--cn-body-(.+)$/, "font-body-"],
    [/^--cn-caption-(.+)$/, "font-caption-"],
    [/^--cn-micro-(.+)$/, "font-micro-"],
  ];
  for (const [re, pfx] of typoPatterns) {
    if ((m = n.match(re))) return [`${pfx}${m[1]}`];
  }

  // comp: link
  if (n === "--cn-comp-link-text-hover") return ["text-cn-brand-hover"];
  if (n === "--cn-comp-link-default") return ["font-link-default"];
  if (n === "--cn-comp-link-sm") return ["font-link-sm"];
  if (n === "--cn-comp-dialog-title") return ["font-dialog-title"];

  // comp: custom bg utilities
  if (n === "--cn-comp-input-bg") return ["bg-cn-input"];
  if (n === "--cn-comp-dialog-backdrop") return ["bg-cn-backdrop"];
  if (n === "--cn-comp-diff-add-content") return ["bg-cn-diff-success"];
  if (n === "--cn-comp-diff-del-content") return ["bg-cn-diff-danger"];
  if (n === "--cn-input-radius") return ["rounded-cn-input"];
  if (n === "--cn-input-size-md") return ["h-cn-input-md"];
  if (n === "--cn-comp-card-fade-default")
    return ["bg-cn-comp-card-fade-default"];
  if (n === "--cn-comp-card-fade-selected")
    return ["bg-cn-comp-card-fade-selected"];

  // comp: data-viz bg
  if ((m = n.match(/^--cn-comp-data-viz-\d+-(.+)$/)))
    return [`bg-cn-data-viz-${m[1]}`];

  // comp: data-viz shadows
  if ((m = n.match(/^--cn-comp-shadow-data-viz-\d+-(.+)$/)))
    return [`shadow-cn-${m[1]}`, `drop-shadow-cn-${m[1]}`];

  return [];
}

// --- Extract all sources ---
const coreVars = extractVariables(styles.core);
const breakpointVars = extractVariables(styles.breakpoint);
const colorsVars = extractVariables(styles.colors);
const componentVars = extractVariables(styles.components);
const semanticVars = extractVariables(styles.light);

// --- Component name map ---
const componentNameMap: Record<string, string> = {
  input: "Input",
  btn: "Button",
  tabs: "Tabs",
  table: "Table",
  card: "Card",
  badge: "Badge",
  tree: "Tree View",
  tag: "Tag",
  toast: "Toast",
  sidebar: "Sidebar",
  drawer: "Drawer",
  progress: "Progress",
  dialog: "Dialog",
  dropdown: "Dropdown",
  accordion: "Accordion",
  popover: "Popover",
  alert: "Alert",
  tooltip: "Tooltip",
  avatar: "Avatar",
  diff: "Diff Editor",
  header: "Header",
  ai: "AI Chat",
  link: "Link",
  pipeline: "Pipeline",
  pagination: "Pagination",
  chart: "Chart",
  markdown: "Markdown",
};

function deriveComponentName(varName: string): string {
  const stripped = varName.replace(/^--cn-comp-/, "").replace(/^--cn-/, "");
  const prefix = stripped.split("-")[0];
  return (
    componentNameMap[prefix] || prefix.charAt(0).toUpperCase() + prefix.slice(1)
  );
}

// --- Categorize semantic tokens (from light.ts theme) ---
function categorizeSemantic(v: Var): Var {
  const n = v.name;
  if (n.startsWith("--cn-bg-"))
    return { ...v, category: "Semantic", subcategory: "Background" };
  if (n.startsWith("--cn-text-"))
    return { ...v, category: "Semantic", subcategory: "Text" };
  if (n.startsWith("--cn-border-"))
    return { ...v, category: "Semantic", subcategory: "Border" };
  if (n.startsWith("--cn-state-"))
    return { ...v, category: "Semantic", subcategory: "State" };
  if (n.startsWith("--cn-disabled"))
    return { ...v, category: "Semantic", subcategory: "State" };
  if (n.startsWith("--cn-focus"))
    return { ...v, category: "Semantic", subcategory: "State" };
  if (n.startsWith("--cn-shadow-"))
    return { ...v, category: "Semantic", subcategory: "Shadows" };
  if (n.startsWith("--cn-ring-"))
    return { ...v, category: "Semantic", subcategory: "Focus Rings" };
  if (n.startsWith("--cn-set-")) {
    const rest = n.replace("--cn-set-", "");
    const setName = rest.split("-")[0];
    const label = setName.charAt(0).toUpperCase() + setName.slice(1);
    return { ...v, category: "Semantic", subcategory: `Set: ${label}` };
  }
  if (n.startsWith("--cn-comp-"))
    return { ...v, category: "Component", subcategory: deriveComponentName(n) };
  if (n.startsWith("--cn-gradient-"))
    return { ...v, category: "Component", subcategory: "Gradients" };
  if (n.startsWith("--cn-icon-"))
    return { ...v, category: "Component", subcategory: "Icons" };
  if (n.startsWith("--cn-img-"))
    return { ...v, category: "Component", subcategory: "Images" };
  if (n.startsWith("--cn-logo-"))
    return { ...v, category: "Component", subcategory: "Logo" };
  if (n.startsWith("--cn-flow-"))
    return { ...v, category: "Component", subcategory: "Flow" };
  return { ...v, category: "Semantic", subcategory: "Other" };
}

// --- Categorize breakpoint module (mixed: typography + layout + comp) ---
function categorizeBreakpoint(v: Var): Var {
  const n = v.name;
  if (n.includes("heading-"))
    return { ...v, category: "Semantic", subcategory: "Headings" };
  if (n.includes("body-"))
    return { ...v, category: "Semantic", subcategory: "Body" };
  if (n.includes("caption-"))
    return { ...v, category: "Semantic", subcategory: "Caption" };
  if (n.includes("micro-"))
    return { ...v, category: "Semantic", subcategory: "Micro" };
  if (n.includes("comp-"))
    return { ...v, category: "Component", subcategory: deriveComponentName(n) };
  if (n.includes("layout-"))
    return { ...v, category: "Semantic", subcategory: "Layout" };
  if (n.includes("shell-"))
    return { ...v, category: "Semantic", subcategory: "Shell" };
  if (n.includes("page-container"))
    return { ...v, category: "Semantic", subcategory: "Page Container" };
  if (n.includes("breakpoint-"))
    return { ...v, category: "Semantic", subcategory: "Breakpoints" };
  return { ...v, category: "Global", subcategory: "Other" };
}

// --- Categorize core module ---
function categorizeCore(v: Var): Var {
  const n = v.name;
  if (n.includes("font-size"))
    return { ...v, category: "Global", subcategory: "Font Size" };
  if (n.includes("line-height"))
    return { ...v, category: "Global", subcategory: "Line Height" };
  if (n.includes("font-weight"))
    return { ...v, category: "Global", subcategory: "Font Weight" };
  if (n.includes("font-family"))
    return { ...v, category: "Global", subcategory: "Font Family" };
  if (n.includes("tracking"))
    return { ...v, category: "Global", subcategory: "Letter Spacing" };
  if (n.includes("text-decoration"))
    return { ...v, category: "Global", subcategory: "Text Decoration" };
  if (n.includes("text-case"))
    return { ...v, category: "Global", subcategory: "Text Case" };
  if (n.includes("cn-size-"))
    return { ...v, category: "Global", subcategory: "Size Scale" };
  if (n.includes("spacing"))
    return { ...v, category: "Global", subcategory: "Spacing Scale" };
  if (n.includes("border-width"))
    return { ...v, category: "Global", subcategory: "Border Width" };
  if (n.includes("rounded"))
    return { ...v, category: "Global", subcategory: "Border Radius" };
  if (n.includes("icon-size"))
    return { ...v, category: "Global", subcategory: "Icon Size" };
  if (n.includes("logo-size"))
    return { ...v, category: "Global", subcategory: "Logo Size" };
  if (n.includes("opacity"))
    return { ...v, category: "Global", subcategory: "Opacity" };
  if (n.includes("animation"))
    return { ...v, category: "Global", subcategory: "Animation" };
  return { ...v, category: "Global", subcategory: "Other" };
}

// --- Build all variables ---
const allSemantic = semanticVars.map(categorizeSemantic);

const allGlobal = [
  ...colorsVars
    .filter((v) => v.name.includes("pure"))
    .map((v) => ({ ...v, category: "Global", subcategory: "Pure Colors" })),
  ...coreVars.map(categorizeCore),
  ...breakpointVars.map(categorizeBreakpoint),
];

const allComponent = componentVars.map((v) => ({
  ...v,
  category: "Component",
  subcategory: deriveComponentName(v.name),
}));

const allVariables = [...allSemantic, ...allGlobal, ...allComponent].map(
  (v) => ({ ...v, twClasses: getTwClasses(v.name) }),
);

import { CSSVariablesClient } from "./docs-page/CSSVariablesClient";
---

<CSSVariablesClient client:load allVariables={allVariables} />
