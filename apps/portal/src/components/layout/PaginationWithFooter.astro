---
import PageFooter from "./PageFooter.astro";

const { dir, pagination } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
---

<div class="pb-cn-4xl">
  <PageFooter />
  <nav class="pagination-links print:hidden" dir={dir}>
    {
      prev && (
        <a href={prev.href} rel="prev">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 16 16"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M14 8H2m0 0 5.667-5.667M2 8l5.667 5.667"
            />
          </svg>
          <span>
            Previous
            <span class="link-title">{prev.label}</span>
          </span>
        </a>
      )
    }
    {
      next && (
        <a href={next.href} rel="next">
          <span>
            Next
            <span class="link-title">{next.label}</span>
          </span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 16 16"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M2 8h12m0 0L8.333 2.333M14 8l-5.667 5.667"
            />
          </svg>
        </a>
      )
    }
  </nav>
</div>

<style>
  .pagination-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
    gap: 1rem;
  }

  .pagination-links a {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    width: 100%;
    flex-grow: 1;
    border: 1px solid var(--cn-border-3);
    border-radius: var(--cn-rounded-6);
    padding: 1rem;
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .pagination-links a[rel="next"] {
    justify-content: flex-end;
    text-align: end;
  }

  .pagination-links a:hover {
    border-color: var(--cn-border-2);
    background: var(--cn-bg-hover);
  }

  .pagination-links a > span {
    color: var(--cn-text-4);
    font-size: var(--cn-font-size-5);
    line-height: 1.4;
  }

  .pagination-links .link-title {
    display: block;
    color: var(--cn-text-1);
    font-size: var(--cn-font-size-4);
    font-weight: 500;
    line-height: 1.3;
    margin-top: 2px;
  }

  .pagination-links svg {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--cn-text-4);
    transition: all 0.15s ease;
  }

  .pagination-links a:hover svg {
    color: var(--cn-text-3);
  }

  .pagination-links a[rel="prev"]:hover svg {
    transform: translateX(-4px);
  }

  .pagination-links a[rel="next"]:hover svg {
    transform: translateX(4px);
  }
</style>
